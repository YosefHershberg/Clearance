# App
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Database (pooled connection for runtime)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Database (direct connection for Prisma migrations)
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Auth
# JWT_SECRET must be ≥ 32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-string-at-least-32-characters-long

# Admin seeder (consumed on boot in Phase 1)
ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=change-me-now

# Anthropic (phase 4b codegen — extraction script generation)
ANTHROPIC_API_KEY=sk-ant-...