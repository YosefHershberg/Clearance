  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/src/index.js",
    "start:test": "NODE_ENV=test node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --config jest.integration.config.js --passWithNoTests",
    "lint": "eslint --fix src",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
